// Contract Net Protocol (CNP) — JaCaMo Application
// n=5 initiators | m=10 participants
//
// To scale for analysis:
//   - vary n: add/remove 'agent inX' entries
//   - vary m: add/remove 'agent paX' entries
//   - vary i: change contracts([...]) list length per initiator (max 9 elements)

mas cnp {

    // =========================================================
    // INITIATORS
    // contracts([1,2,...,i]) = list of contract indices to run in parallel
    // service(S)             = requested service: compute/storage/network
    // =========================================================
    agent in1 : initiator.asl {
        beliefs: contracts([1,2,3]), service(compute)
    }
    agent in2 : initiator.asl {
        beliefs: contracts([1,2]), service(storage)
    }
    agent in3 : initiator.asl {
        beliefs: contracts([1]), service(network)
    }
    agent in4 : initiator.asl {
        beliefs: contracts([1,2,3]), service(compute)
    }
    agent in5 : initiator.asl {
        beliefs: contracts([1,2]), service(storage)
    }

    // =========================================================
    // PARTICIPANTS
    // service(S)   = the service this agent offers
    // strategy(S)  = pricing strategy:
    //   random      — price from [55, 80, 100, 120, 145]
    //   fixed       — always 80
    //   aggressive  — price from [30, 35, 40, 45, 50]
    //   conservative— price from [100, 110, 120, 135, 150]
    // =========================================================
    agent pa1 : participant.asl {
        beliefs: service(compute), strategy(random)
    }
    agent pa2 : participant.asl {
        beliefs: service(storage), strategy(fixed)
    }
    agent pa3 : participant.asl {
        beliefs: service(network), strategy(aggressive)
    }
    agent pa4 : participant.asl {
        beliefs: service(compute), strategy(conservative)
    }
    agent pa5 : participant.asl {
        beliefs: service(storage), strategy(random)
    }
    agent pa6 : participant.asl {
        beliefs: service(network), strategy(fixed)
    }
    agent pa7 : participant.asl {
        beliefs: service(compute), strategy(aggressive)
    }
    agent pa8 : participant.asl {
        beliefs: service(storage), strategy(conservative)
    }
    agent pa9 : participant.asl {
        beliefs: service(network), strategy(random)
    }
    agent pa10 : participant.asl {
        beliefs: service(compute), strategy(fixed)
    }

}
